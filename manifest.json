{
  "manifest_version": 3,
  "name": "BrandResume Auto-Apply",
  "version": "1.2",
  "description": "JobRight-style sidepanel for automated application processing.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open BrandResume"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}