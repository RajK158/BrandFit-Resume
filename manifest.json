{
  "manifest_version": 3,
  "name": "BrandResume Auto-Apply",
  "version": "1.0",
  "description": "Autofills job applications instantly.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}